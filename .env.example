# ============================================
# Delegacje App — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Used by: docker-compose.ghcr.yml (and docker-compose.yml)

# --- Database ---
DB_PASSWORD=change_me_to_a_strong_password

# --- JWT Secrets (min 32 characters each) ---
# Generate with: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_jwt_refresh_secret_min_32_chars

# --- App Settings ---
# CORS_ORIGIN: frontend URL (default: http://localhost:8250)
CORS_ORIGIN=http://localhost:8250

# APP_PORT: port on which the app is exposed (default: 8250)
APP_PORT=8250

# --- Image Version (docker-compose.ghcr.yml only) ---
# Pin to a specific release tag, or leave empty for "latest"
# DELEGACJE_VERSION=v1.4.1

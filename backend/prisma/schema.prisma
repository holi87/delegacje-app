generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// USERS
// =====================

enum Role {
  ADMIN
  DELEGATED
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  role         Role         @default(DELEGATED)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  profile     UserProfile?
  delegations Delegation[]

  @@map("users")
}

model UserProfile {
  id              String      @id @default(uuid())
  userId          String      @unique @map("user_id")
  firstName       String      @map("first_name")
  lastName        String      @map("last_name")
  position        String
  defaultVehicle  VehicleType? @map("default_vehicle")
  vehiclePlate    String?     @map("vehicle_plate")
  vehicleCapacity String?     @map("vehicle_capacity")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// =====================
// DELEGATIONS
// =====================

enum DelegationStatus {
  DRAFT
  SUBMITTED
  SETTLED
}

enum DelegationType {
  DOMESTIC
  FOREIGN
}

enum TransportType {
  COMPANY_VEHICLE
  PUBLIC_TRANSPORT
  PRIVATE_VEHICLE
  MIXED
}

enum VehicleType {
  CAR_ABOVE_900
  CAR_BELOW_900
  MOTORCYCLE
  MOPED
}

enum AccommodationType {
  RECEIPT
  LUMP_SUM
  FREE
  NONE
}

model Delegation {
  id   String           @id @default(uuid())
  number Int            @unique
  numberLabel String    @unique @map("number_label")
  userId String         @map("user_id")
  type   DelegationType @default(DOMESTIC)
  status DelegationStatus @default(DRAFT)

  purpose     String
  destination String
  departureAt DateTime @map("departure_at")
  returnAt    DateTime @map("return_at")

  transportType  TransportType @map("transport_type")
  vehicleType    VehicleType?  @map("vehicle_type")
  transportNotes String?       @map("transport_notes")

  accommodationType   AccommodationType @default(NONE) @map("accommodation_type")
  accommodationNights Int               @default(0) @map("accommodation_nights")
  accommodationTotal  Decimal?          @db.Decimal(10, 2) @map("accommodation_total")

  advanceAmount Decimal @default(0) @db.Decimal(10, 2) @map("advance_amount")

  totalDiet          Decimal? @db.Decimal(10, 2) @map("total_diet")
  totalAccommodation Decimal? @db.Decimal(10, 2) @map("total_accommodation")
  totalTransport     Decimal? @db.Decimal(10, 2) @map("total_transport")
  totalAdditional    Decimal? @db.Decimal(10, 2) @map("total_additional")
  grandTotal         Decimal? @db.Decimal(10, 2) @map("grand_total")
  amountDue          Decimal? @db.Decimal(10, 2) @map("amount_due")

  foreignCountry      String?   @map("foreign_country")
  foreignCurrency     String?   @map("foreign_currency")
  foreignRateId       String?   @map("foreign_rate_id")
  borderCrossingOut   DateTime? @map("border_crossing_out")  // wyjazd z PL
  borderCrossingIn    DateTime? @map("border_crossing_in")   // powrót do PL
  totalDomesticDiet   Decimal?  @db.Decimal(10, 2) @map("total_domestic_diet")   // dieta za odcinek krajowy
  totalForeignDiet    Decimal?  @db.Decimal(10, 2) @map("total_foreign_diet")    // dieta za odcinek zagraniczny

  exchangeRate        Decimal?  @db.Decimal(10, 4) @map("exchange_rate")       // kurs NBP
  exchangeRateDate    DateTime? @db.Date @map("exchange_rate_date")             // data kursu
  exchangeRateTable   String?   @map("exchange_rate_table")                     // nr tabeli NBP

  settledAt DateTime? @map("settled_at")
  settledBy String?   @map("settled_by")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id])
  days              DelegationDay[]
  additionalCosts   AdditionalCost[]
  mileageDetails    MileageDetails?
  transportReceipts TransportReceipt[]

  @@index([userId])
  @@index([status])
  @@map("delegations")
}

model DelegationDay {
  id           String   @id @default(uuid())
  delegationId String   @map("delegation_id")
  dayNumber    Int      @map("day_number")
  date         DateTime @db.Date
  hoursInDay   Decimal  @db.Decimal(4, 2) @map("hours_in_day")

  breakfastProvided Boolean @default(false) @map("breakfast_provided")
  lunchProvided     Boolean @default(false) @map("lunch_provided")
  dinnerProvided    Boolean @default(false) @map("dinner_provided")

  accommodationType AccommodationType @default(NONE) @map("accommodation_type")
  accommodationCost Decimal?          @db.Decimal(10, 2) @map("accommodation_cost")
  accommodationReceiptNumber String?  @map("accommodation_receipt_number")
  accommodationCurrency String?       @map("accommodation_currency")

  dietBase       Decimal? @db.Decimal(10, 2) @map("diet_base")
  dietDeductions Decimal? @db.Decimal(10, 2) @map("diet_deductions")
  dietFinal      Decimal? @db.Decimal(10, 2) @map("diet_final")

  // Foreign delegation fields
  isForeign      Boolean  @default(false) @map("is_foreign")  // true = foreign segment day
  dietRate       Decimal? @db.Decimal(10, 2) @map("diet_rate") // frozen rate used for this day

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)

  @@unique([delegationId, dayNumber])
  @@map("delegation_days")
}

model MileageDetails {
  id           String      @id @default(uuid())
  delegationId String      @unique @map("delegation_id")
  vehicleType  VehicleType @map("vehicle_type")
  engineCapacityCm3 Int?   @map("engine_capacity_cm3")
  vehiclePlate String      @map("vehicle_plate")
  distanceKm   Decimal     @db.Decimal(10, 1) @map("distance_km")
  ratePerKm    Decimal     @db.Decimal(5, 2) @map("rate_per_km")
  totalAmount  Decimal     @db.Decimal(10, 2) @map("total_amount")

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  segments   MileageSegment[]

  @@map("mileage_details")
}

model MileageSegment {
  id              String   @id @default(uuid())
  mileageDetailsId String  @map("mileage_details_id")
  segmentNumber   Int      @map("segment_number")
  date            DateTime @db.Date
  startLocation   String   @map("start_location")
  endLocation     String   @map("end_location")
  km              Decimal  @db.Decimal(10, 1)

  mileageDetails MileageDetails @relation(fields: [mileageDetailsId], references: [id], onDelete: Cascade)

  @@unique([mileageDetailsId, segmentNumber])
  @@map("mileage_segments")
}

model TransportReceipt {
  id           String  @id @default(uuid())
  delegationId String  @map("delegation_id")
  description  String
  amount       Decimal @db.Decimal(10, 2)
  receiptNumber String? @map("receipt_number")

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)

  @@map("transport_receipts")
}

model AdditionalCost {
  id           String  @id @default(uuid())
  delegationId String  @map("delegation_id")
  description  String
  category     String
  amount       Decimal @db.Decimal(10, 2)
  receiptNumber String? @map("receipt_number")

  delegation Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)

  @@map("additional_costs")
}

// =====================
// RATES (ADMIN)
// =====================

model DomesticRate {
  id                      String    @id @default(uuid())
  dailyDiet               Decimal   @db.Decimal(10, 2) @map("daily_diet")
  accommodationLumpSum    Decimal   @db.Decimal(10, 2) @map("accommodation_lump_sum")
  accommodationMaxReceipt Decimal   @db.Decimal(10, 2) @map("accommodation_max_receipt")
  localTransportLumpSum   Decimal   @db.Decimal(10, 2) @map("local_transport_lump_sum")
  breakfastDeductionPct   Int       @default(25) @map("breakfast_deduction_pct")
  lunchDeductionPct       Int       @default(50) @map("lunch_deduction_pct")
  dinnerDeductionPct      Int       @default(25) @map("dinner_deduction_pct")
  validFrom               DateTime  @map("valid_from")
  validTo                 DateTime? @map("valid_to")
  createdAt               DateTime  @default(now()) @map("created_at")

  @@map("domestic_rates")
}

model MileageRate {
  id          String      @id @default(uuid())
  vehicleType VehicleType @map("vehicle_type")
  ratePerKm   Decimal     @db.Decimal(5, 2) @map("rate_per_km")
  validFrom   DateTime    @map("valid_from")
  validTo     DateTime?   @map("valid_to")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@map("mileage_rates")
}

model ForeignDietRate {
  id                    String    @id @default(uuid())
  countryCode           String    @map("country_code")
  countryName           String    @map("country_name")
  currency              String
  dailyDiet             Decimal   @db.Decimal(10, 2) @map("daily_diet")
  accommodationLimit    Decimal   @db.Decimal(10, 2) @map("accommodation_limit")
  breakfastDeductionPct Int       @default(15) @map("breakfast_deduction_pct")
  lunchDeductionPct     Int       @default(30) @map("lunch_deduction_pct")
  dinnerDeductionPct    Int       @default(30) @map("dinner_deduction_pct")
  validFrom             DateTime  @map("valid_from")
  validTo               DateTime? @map("valid_to")
  createdAt             DateTime  @default(now()) @map("created_at")

  @@unique([countryCode, validFrom])
  @@map("foreign_diet_rates")
}

// =====================
// COMPANY
// =====================

model CompanyInfo {
  id         String   @id @default(uuid())
  name       String
  nip        String
  address    String
  city       String
  postalCode String   @map("postal_code")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("company_info")
}

model DelegationNumberCounter {
  key       String @id
  nextValue Int    @default(1) @map("next_value")

  @@map("delegation_number_counter")
}

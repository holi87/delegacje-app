# Database
DATABASE_URL="postgresql://delegacje_user:your_password@localhost:5432/delegacje"

# JWT — use strong random secrets (min 32 chars), e.g.: openssl rand -base64 48
JWT_SECRET="change-me-min-32-characters-long-secret"
JWT_REFRESH_SECRET="change-me-min-32-characters-long-refresh-secret"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — frontend URL (dev: Vite, prod: nginx)
CORS_ORIGIN=http://localhost:8250
